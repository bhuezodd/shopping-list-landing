---
// Replace this with your real store URL once the app is published.
const playStoreUrl = '#';
---

<section class="download" id="download">
  <div class="container download-card">
    <div class="glow" aria-hidden="true"></div>
    <span class="section-eyebrow">Get started</span>
    <h2 class="section-title">Ready to shop smarter?</h2>
    <p class="section-subtitle download-subtitle">
      Download Shopping List by AI and turn your next shopping trip into a
      breeze. It is free.
    </p>

    <div class="store-buttons">
      <a class="store-btn" href={playStoreUrl} aria-label="Get it on Google Play">
        <span class="store-icon" aria-hidden="true">▶</span>
        <span class="store-text">
          <small>Get it on</small>
          <strong>Google Play</strong>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .download {
    padding-block: var(--space-5xl);
  }

  .download-card {
    position: relative;
    overflow: hidden;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: linear-gradient(160deg, var(--surface-light), var(--surface));
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: var(--space-5xl) var(--space-2xl);
  }

  .glow {
    position: absolute;
    top: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 500px;
    background: radial-gradient(
      circle,
      rgba(155, 109, 255, 0.25),
      transparent 60%
    );
    z-index: 0;
  }

  .download-card > * {
    position: relative;
    z-index: 1;
  }

  .download-subtitle {
    margin-block: var(--space-md) var(--space-2xl);
  }

  .store-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-lg);
  }

  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    background: var(--background);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 12px 22px;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }

  .store-btn:hover {
    transform: translateY(-2px);
    border-color: var(--primary);
  }

  .store-icon {
    font-size: 24px;
    color: var(--primary-light);
  }

  .store-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    text-align: left;
  }

  .store-text small {
    font-size: 11px;
    color: var(--text-muted);
  }

  .store-text strong {
    font-size: 17px;
  }
</style>
