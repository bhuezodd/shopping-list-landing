---
// Mock list items shown inside the phone preview.
const previewItems = [
  { name: 'Avocados', qty: '3', done: false },
  { name: 'Whole milk', qty: '1L', done: false },
  { name: 'Sourdough bread', qty: '1', done: true },
  { name: 'Free-range eggs', qty: '12', done: false },
  { name: 'Dark chocolate', qty: '2', done: true },
];
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      <img class="hero-logo" src="/logo.png" alt="Shopping List logo" width="72" height="72" />
      <span class="section-eyebrow">Smart shopping, simplified</span>
      <h1 class="hero-title">
        Your shopping list,<br />
        <span class="hero-gradient">made simple.</span>
      </h1>
      <p class="hero-subtitle">
        Create lists in seconds, reuse the products you buy most, and stay
        organized with smart categories — so every trip to the store is faster.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="/#download">Download free</a>
        <a class="btn btn-secondary" href="/#features">See features</a>
      </div>

      <p class="hero-note">Free to use · Available on Android · No account required</p>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="phone">
        <div class="phone-notch"></div>
        <div class="phone-screen">
          <p class="phone-header">Weekly Groceries</p>
          <p class="phone-subheader">5 items · 2 done</p>
          <ul class="phone-list">
            {
              previewItems.map((item) => (
                <li class={`phone-item${item.done ? ' is-done' : ''}`}>
                  <span class="check">{item.done ? '✓' : ''}</span>
                  <span class="item-name">{item.name}</span>
                  <span class="item-qty">{item.qty}</span>
                </li>
              ))
            }
          </ul>
          <div class="phone-add">+ Add product</div>
        </div>
      </div>
      <div class="glow"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-5xl);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: var(--space-4xl);
  }

  .hero-logo {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    margin-bottom: var(--space-xl);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
  }

  .hero-title {
    font-size: clamp(36px, 6vw, 60px);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-block: var(--space-md) var(--space-xl);
  }

  .hero-gradient {
    background: linear-gradient(120deg, var(--primary-light), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-subtitle {
    font-size: 19px;
    color: var(--text-secondary);
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
  }

  .hero-note {
    margin-top: var(--space-lg);
    color: var(--text-muted);
    font-size: 14px;
  }

  /* Phone mockup */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 60% 40%,
      rgba(155, 109, 255, 0.35),
      transparent 60%
    );
    filter: blur(40px);
    z-index: -1;
  }

  .phone {
    position: relative;
    width: 290px;
    background: var(--surface);
    border: 1px solid var(--border-light);
    border-radius: 38px;
    padding: 14px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
  }

  .phone-notch {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 22px;
    background: var(--background);
    border-radius: var(--radius-full);
  }

  .phone-screen {
    background: var(--background);
    border-radius: 28px;
    padding: 40px 18px 18px;
  }

  .phone-header {
    font-size: 20px;
    font-weight: 700;
  }

  .phone-subheader {
    color: var(--text-muted);
    font-size: 13px;
    margin-bottom: var(--space-lg);
  }

  .phone-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .phone-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    font-size: 15px;
  }

  .phone-item .check {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    border: 2px solid var(--border-light);
    border-radius: var(--radius-sm);
    display: grid;
    place-items: center;
    font-size: 12px;
    color: var(--text-on-primary);
  }

  .phone-item.is-done {
    opacity: 0.55;
  }

  .phone-item.is-done .check {
    background: var(--primary);
    border-color: var(--primary);
  }

  .phone-item.is-done .item-name {
    text-decoration: line-through;
  }

  .item-name {
    flex: 1;
  }

  .item-qty {
    color: var(--text-muted);
    font-size: 13px;
  }

  .phone-add {
    margin-top: var(--space-lg);
    text-align: center;
    color: var(--primary-light);
    font-weight: 600;
    background: var(--surface-light);
    border: 1px dashed var(--border-light);
    border-radius: var(--radius-md);
    padding: 12px;
    font-size: 14px;
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-visual {
      margin-top: var(--space-2xl);
    }
  }
</style>
