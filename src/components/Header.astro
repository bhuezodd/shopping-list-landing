---
const navLinks = [
  { label: 'Features', href: '/#features' },
  { label: 'How it works', href: '/#how-it-works' },
  { label: 'Download', href: '/#download' },
];
---

<header class="header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <img class="brand-mark" src="/logo.png" alt="Shopping List by AI logo" width="32" height="32" />
      <span class="brand-name">Shopping List <span class="brand-ai">by AI</span></span>
    </a>

    <nav class="nav" aria-label="Primary">
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <a class="btn btn-primary header-cta" href="/#download">Get the app</a>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(26, 16, 37, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2xl);
    height: 68px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-weight: 700;
    font-size: 18px;
  }

  .brand-mark {
    width: 32px;
    height: 32px;
    border-radius: 8px;
  }

  .brand-ai {
    color: var(--accent);
  }

  .nav {
    display: flex;
    gap: var(--space-2xl);
    color: var(--text-secondary);
    font-size: 15px;
    font-weight: 500;
  }

  .nav a:hover {
    color: var(--text-primary);
  }

  .header-cta {
    padding: 10px 18px;
    font-size: 15px;
  }

  @media (max-width: 760px) {
    .nav {
      display: none;
    }
  }
</style>
